{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "stacked_bar_repo_severity",
  "position": {
    "x": 20,
    "y": 80,
    "z": 1000,
    "height": 420,
    "width": 820,
    "tabOrder": 1000
  },
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Fact_FinOpsFindings"
                    }
                  },
                  "Property": "RepositoryKey"
                }
              },
              "queryRef": "Fact_FinOpsFindings.RepositoryKey",
              "nativeQueryRef": "Repository",
              "active": true
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Severity"
                    }
                  },
                  "Property": "Severity"
                }
              },
              "queryRef": "Dim_Severity.Severity",
              "nativeQueryRef": "Severity"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Fact_FinOpsFindings"
                    }
                  },
                  "Property": "Total Findings"
                }
              },
              "queryRef": "Fact_FinOpsFindings.Total Findings",
              "nativeQueryRef": "Total Findings"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Measure": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "Fact_FinOpsFindings"
                  }
                },
                "Property": "Total Findings"
              }
            },
            "direction": "Descending"
          }
        ],
        "isDefaultSort": true
      }
    },
    "objects": {
      "legend": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "position": {
              "expr": {
                "Literal": {
                  "Value": "'Top'"
                }
              }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'FinOps Findings by Repository'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}