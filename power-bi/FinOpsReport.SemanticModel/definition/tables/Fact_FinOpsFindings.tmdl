table Fact_FinOpsFindings
	lineageTag: 66cbc04c-9e57-4dc4-9263-5022d2d2a830

	measure 'Total Findings' = COUNTROWS(Fact_FinOpsFindings)
		formatString: 0
		lineageTag: 858a574b-a019-4fee-aba1-0f0dc8c21972

	measure 'Open Findings' = CALCULATE(COUNTROWS(Fact_FinOpsFindings), Fact_FinOpsFindings[State] = "open")
		formatString: 0
		lineageTag: 2763dd4c-aa2b-4b40-af4e-3d9e7d38ccb1

	measure 'Fixed Findings' = CALCULATE(COUNTROWS(Fact_FinOpsFindings), Fact_FinOpsFindings[State] = "fixed")
		formatString: 0
		lineageTag: 05efe465-4cee-4627-85c8-1db0bbd30206

	measure 'Total Dismissed' = CALCULATE(COUNTROWS(Fact_FinOpsFindings), Fact_FinOpsFindings[State] = "dismissed")
		formatString: 0
		lineageTag: f46d8a1f-aeb6-4e9a-b5b9-8f828096ed23

	measure 'Compliance Rate' = DIVIDE([Fixed Findings], [Fixed Findings] + [Open Findings] + [Total Dismissed], 0)
		formatString: 0.0%
		lineageTag: 5f5295fc-c630-4b9c-97b5-274be1701a92

	measure 'Critical Findings' = CALCULATE(COUNTROWS(Fact_FinOpsFindings), Dim_Severity[Severity] = "Critical")
		formatString: 0
		lineageTag: 83213d34-4ce9-403d-a0fe-83e896c23d7c

	measure 'Warning Findings' = CALCULATE(COUNTROWS(Fact_FinOpsFindings), Dim_Severity[Severity] = "Medium")
		formatString: 0
		lineageTag: 00ce4805-733b-4c61-a93d-f4ea5bb6aed5

	measure 'Cost Savings Potential' = CALCULATE(SUM(Fact_FinOpsFindings[EstimatedSavings]), Fact_FinOpsFindings[State] = "open")
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 26ddf310-91c2-4978-8a4e-86958c70d59d

	measure 'Repositories Scanned' = DISTINCTCOUNT(Fact_FinOpsFindings[RepositoryKey])
		formatString: 0
		lineageTag: d423f47e-2ff1-4759-9113-189564d502fc

	measure 'Mean Time to Remediate' = AVERAGEX(FILTER(Fact_FinOpsFindings, NOT(ISBLANK(Fact_FinOpsFindings[FixedDate]))), DATEDIFF(Fact_FinOpsFindings[ScanDate], Fact_FinOpsFindings[FixedDate], DAY))
		formatString: 0
		lineageTag: d36382d3-9a76-48cc-89b6-21bb46fdaaa6

