	partition Fact_FinOpsFindings = m
		mode: import
		source =
				let
					StorageUrl = "https://" & StorageAccountName & ".blob.core.windows.net/" & ContainerName,
					Source = AzureStorage.Blobs(StorageUrl),
					FilteredRows = Table.SelectRows(Source, each Text.EndsWith([Name], ".json")),
					ParsedContent = Table.AddColumn(FilteredRows, "ParsedJson", each let p = Json.Document([Content]) in if p is list then p else {p}),
					ExpandedRows = Table.ExpandListColumn(ParsedContent, "ParsedJson"),
					ExpandedCols = Table.ExpandRecordColumn(ExpandedRows, "ParsedJson",
						{"FindingId", "RuleId", "RuleDescription", "Severity", "SeverityKey",
						 "State", "ToolName", "RepositoryKey", "ResourceName",
						 "FilePath", "LineNumber", "EstimatedSavings",
						 "ScanDate", "FixedDate", "ScanRunId"})
				in
					ExpandedCols

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

